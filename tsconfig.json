{
  "compilerOptions": {
    "target": "ES6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/public/*": [
        "./public/*"
      ],
      "react-twemoji": [
        "./types/react-twemoji"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./src/types",
      "./types"
    ],
    "incremental": true
  },
  "allowSyntheticDefaultImports": true,
  "exclude": [
    "node_modules"
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "next.config.js",
    "tailwind.config.js",
    "postcss.config.js",
    "components/utils/index.js",
    "lib/ga/index.js"
  ]
}
